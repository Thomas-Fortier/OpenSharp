{
  "metadata": [
    {
      "src": [
        {
          "files": [ "src/OpenSharp.Core/OpenSharp.Core.csproj" ],
          "src": "."
        }
      ],
      "dest": "docs/api",
      "properties": {
        "TargetFramework": "net8.0"
      }
    }
  ],
  "build": {
    "content": [
      { "files": [ "docs/api/**.yml", "docs/api/index.md" ] },
      { "files": [ "README.md" ] }
    ],
    "dest": "docs/_site",
    "globalMetadata": {
      "_appTitle": "OpenSharp.Core API Reference",
      "_enableSearch": true
    },
    "template": [ "default", "modern" ]
  }
}
