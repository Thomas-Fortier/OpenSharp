{
  "metadata": [
    {
      "src": [
        {
          "files": [ "src/OpenSharp.Core/OpenSharp.Core.csproj" ],
          "src": "."
        }
      ],
      "dest": "docs/api",
      "properties": {
        "TargetFramework": "net8.0"
      }
    }
  ],
  "build": {
    "content": [
      {
        "files": [ "**/*.{md,yml}" ],
        "src": "docs",
        "dest": "."
      }
    ],
    "dest": "docs/_site",
    "globalMetadata": {
      "_appName": "OpenSharp",
      "_appTitle": "OpenSharp.Core API Reference",
      "_enableSearch": true
    },
    "template": [ "default", "modern" ]
  }
}
